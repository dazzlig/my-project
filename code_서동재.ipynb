   "source": [
    "na_columns_train = train_x.columns[train_x.isna().any()]\n",
    "na_columns_test = test_x.columns[test_x.isna().any()]\n",
    "na_columns = set(na_columns_train) | set(na_columns_test)\n",
    "na_columns"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "2. 데이터를 정규화 합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_final_features(df):\n",
    "    \"\"\"핵심 피처를 바탕으로 상호작용 및 비율 피처를 생성하는 함수\"\"\"\n",
    "    \n",
    "    # 복사본을 만들어 원본 데이터가 변경되는 것을 방지합니다.\n",
    "    df_copy = df.copy()\n",
    "    \n",
    "    # 히트맵과 데이터 종류를 바탕으로 최종 선택된 key_features\n",
    "    key_features = ['mean_deltaQ_dchg_3_0', 'avg_stress', 'min_deltaQ', 'mean_dqdv_dchg_low_3_0']\n",
    "    \n",
    "    # 상호작용 피처 생성\n",
    "    poly = PolynomialFeatures(degree=2, include_bias=False, interaction_only=True)\n",
    "    interaction_df = poly.fit_transform(df_copy[key_features])\n",
    "    interaction_cols = poly.get_feature_names_out(key_features)\n",
    "    interaction_df = pd.DataFrame(interaction_df, columns=interaction_cols, index=df_copy.index)\n",
    "    \n",
    "    # 비율 피처 생성\n",
    "    epsilon = 1e-6\n",
    "    df_copy['stability_metric'] = df_copy['min_deltaQ'] / (df_copy['var_deltaQ'] + epsilon)\n",
    "    \n",
    "    # 최종 데이터프레임 병합\n",
    "    final_df = pd.concat([df_copy, interaction_df], axis=1)\n",
    "    # 중복된 컬럼 이름이 있다면 제거\n",
    "    final_df = final_df.loc[:,~final_df.columns.duplicated()]\n",
    "\n",
    "    return final_df\n",
    "\n",
    "train_x = create_final_features(train_x)\n",
    "test_x = create_final_features(test_x)"
   ]
  },
