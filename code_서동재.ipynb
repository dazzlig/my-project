  {
   "cell_type": "code",
   "execution_count": 15,
   "metadata": {},
   "outputs": [],
   "source": [
    "n_splits=10\n",
    "kf = KFold(n_splits=n_splits , shuffle=True ,random_state=42)\n",
    "\n",
    "test_preds_rf = np.zeros((len(test_x), n_splits))\n",
    "test_preds_svr = np.zeros((len(test_x), n_splits))\n",
    "test_preds_gbr = np.zeros((len(test_x), n_splits))\n",
    "\n",
    "oof_preds_rf = np.zeros(len(train_x))\n",
    "oof_preds_svr = np.zeros(len(train_x))\n",
    "oof_preds_gbr = np.zeros(len(train_x))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 모델 학습\n",
    "\n",
    "모델은 각자 자유롭게 구성할 수 있으며, 올바른 형식으로 `submission.csv`를 작성한다면 다양한 모델이 허용됩니다.\n",
    "\n",
    "아래는 이해를 돕기 위한 예시 코드로, 간단한 서포트 벡터 머신 기반 회귀 예측 모델 (SVR) 을 사용합니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "--- Fold 1---\n",
      "--- Fold 2---\n",
      "--- Fold 3---\n",
      "--- Fold 4---\n",
      "--- Fold 5---\n",
      "--- Fold 6---\n",
      "--- Fold 7---\n",
      "--- Fold 8---\n",
      "--- Fold 9---\n",
      "--- Fold 10---\n"
     ]
    }
   ],
   "source": [
    "for i, (train_index, val_index) in enumerate(kf.split(train_x)):\n",
    "    print(f\"--- Fold {i+1}---\")\n",
    "    \n",
    "    # K-Fold에 맞게 훈련/검증 데이터 분리\n",
    "    X_train, X_val = train_x.iloc[train_index], train_x.iloc[val_index]\n",
    "    y_train, y_val = train_y.iloc[train_index], train_y.iloc[val_index]\n",
    "\n",
    "    # ** 중요: Scaler는 반드시 루프 안에서 fit 되어야 데이터 누수가 없습니다. **\n",
    "    scaler = StandardScaler()\n",
    "    X_train_scaled = scaler.fit_transform(X_train)\n",
    "    X_val_scaled = scaler.transform(X_val)\n",
    "    test_x_scaled = scaler.transform(test_x) # 테스트 데이터도 매번 동일하게 스케일링\n",
    "\n",
    "    # (A) SVR 모델 학습 및 예측\n",
    "    svr_model = SVR(C=1.0, gamma=0.01, kernel='rbf' ,epsilon=0.01) # 최적 파라미터 사용\n",
    "    svr_model.fit(X_train_scaled, y_train)\n",
    "    oof_preds_svr[val_index] = svr_model.predict(X_val_scaled)\n",
    "    test_preds_svr[:, i] = svr_model.predict(test_x_scaled)\n",
    "    \n",
    "    # (B) RandomForest 모델 학습 및 예측\n",
    "    rf_model = RandomForestRegressor(n_estimators=1000, max_depth=70,min_samples_split=2, max_features='log2', random_state=42, n_jobs=-1) # 최적 파라미터 사용\n",
    "    rf_model.fit(X_train, y_train)\n",
    "    oof_preds_rf[val_index] = rf_model.predict(X_val)\n",
    "    test_preds_rf[:, i] = rf_model.predict(test_x)\n",
    "    \n",
    "    gbr_model = GradientBoostingRegressor(random_state=42, n_estimators=500, learning_rate=0.01, max_depth=3)\n",
    "    gbr_model.fit(X_train, y_train)\n",
    "    oof_preds_gbr[val_index] = gbr_model.predict(X_val)\n",
    "    test_preds_gbr[:, i] = gbr_model.predict(test_x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "metadata": {},
   "outputs": [],
   "source": [
    "final_test_rf_log = test_preds_rf.mean(axis=1)\n",
    "final_test_svr_log = test_preds_svr.mean(axis=1)\n",
    "final_test_gbr_log = test_preds_gbr.mean(axis=1)\n",
    "\n",
    "X_train_meta = pd.DataFrame({\n",
    "    'rf_oof': oof_preds_rf, \n",
    "    'svr_oof': oof_preds_svr,\n",
    "    'hgbr_oof': oof_preds_gbr\n",
    "})\n",
    "X_test_meta = pd.DataFrame({\n",
    "    'rf_oof': final_test_rf_log, \n",
    "    'svr_oof': final_test_svr_log, \n",
    "    'hgbr_oof': final_test_gbr_log\n",
    "})\n",
    "\n",
    "meta_model = Ridge(alpha=0.01 , random_state=42)\n",
    "meta_model.fit(X_train_meta, train_y)\n",
    "\n",
    "final_pred_log = meta_model.predict(X_test_meta)\n",
    "final_pred_original = np.expm1(final_pred_log)\n",
    "\n",
    "# meta_model = lgb.LGBMRegressor(random_state=42)\n",
    "# meta_model.fit(X_train_meta, train_y)\n",
    "\n",
    "# final_pred_log = best_model.predict(X_test_meta)\n",
    "# final_pred_original = np.expm1(final_pred_log)"
   ]
